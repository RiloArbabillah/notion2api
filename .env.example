# ==========================================
# Notion-AI Configuration Template / 服务配置文件（示例）
# Copy this file to .env and fill in actual values / 复制此文件为 .env 并填入实际值
# ==========================================

# ----------------------------------------------------------
# 1. Core Credentials: Notion Account Pool (JSON Array Format)
#    核心凭据：Notion 账号配置池（JSON 数组格式）
# ----------------------------------------------------------
# Must include: token_v2, space_id, user_id / 必须包含：token_v2, space_id, user_id
# Multiple accounts enable load balancing and rate limit rotation / 多组账号可以实现轮询防风控
#
# Recommended: run `python login.py` to launch Chrome, capture the active
# Notion session locally, and update accounts.json/.env automatically.
# 推荐：运行 `python login.py`，脚本会启动 Chrome，在本地读取当前 Notion
# 登录会话，并自动更新 accounts.json/.env。
#
# Legacy manual fallback: copy token_v2 from DevTools, then run
# scripts/extract_notion_info.js in the browser console to get the other fields.
# 旧版手动方式：从 DevTools 复制 token_v2，再在浏览器 Console 运行
# scripts/extract_notion_info.js 获取其他字段。
# ----------------------------------------------------------
NOTION_ACCOUNTS='[{"profile_name":"default","token_v2":"your_token","space_id":"your_space","user_id":"your_uid","space_view_id":"your_view","user_name":"your_name","user_email":"your_email"}]'

# ----------------------------------------------------------
# 2. FastAPI Service & Security / FastAPI 服务与安全
# ----------------------------------------------------------
# API_KEY: Bearer Token required for client requests to /v1/chat/completions
#          客户端请求 /v1/chat/completions 时需携带的 Bearer Token
# Leave empty to disable auth (not recommended for production) / 留空代表不鉴权（生产环境建议设置）
API_KEY=

# HOST: Service binding IP. 0.0.0.0 allows external network access
#       服务绑定的 IP。0.0.0.0 允许外部网段访问
HOST=0.0.0.0

# ALLOWED_ORIGINS: Comma-separated list of allowed origins for CORS.
#                  Use "*" to allow all origins (not recommended for production).
#                  CORS 允许的域名列表，逗号分隔。生产环境建议设置具体域名，"*" 代表允许所有（不建议）。
ALLOWED_ORIGINS=*

# PORT: Service listening port (container internal port; host port configured in docker-compose.yml)
#       服务监听端口（容器内部端口，宿主机端口在 docker-compose.yml 中配置）
PORT=8000

# APP_MODE: Application运行模式
# - standard: Full context, supports thinking & search, no database (default, recommended) / 完整上下文，支持 thinking 和搜索，无数据库（默认，推荐）
# - lite: Single-turn Q&A, no memory, no database / 单轮问答，无记忆，无数据库
# - heavy: Full session management, requires SQLite + SILICONFLOW_API_KEY / 完整会话管理，需要 SQLite + SILICONFLOW_API_KEY
APP_MODE=standard

# ----------------------------------------------------------
# 3. Docker Configuration / Docker 配置
# ----------------------------------------------------------
# HOST_PORT: Host exposed port (for docker-compose) / 宿主机暴露的端口（用于 docker-compose）
HOST_PORT=8000

# ----------------------------------------------------------
# 4. Data Persistence (SQLite) / 数据持久化（SQLite）
# ----------------------------------------------------------
# DB_PATH: Chat history database file path / 聊天记录数据库文件路径
# Note: Overridden by docker-compose.yml to /app/data/conversations.db in Docker deployment
#       注意：Docker 部署时会被 docker-compose.yml 覆盖为 /app/data/conversations.db
# For local development, use relative path: ./data/conversations.db / 本地开发时可以使用相对路径：./data/conversations.db
DB_PATH=./data/conversations.db

# ----------------------------------------------------------
# 5. Advanced Configuration (Optional) / 高级配置（可选）
# ----------------------------------------------------------
# SILICONFLOW_API_KEY: For SiliconFlow service (backup solution) / 如果使用 SiliconFlow 服务（备用方案）
SILICONFLOW_API_KEY=

# NOTION_CLIENT_VERSION: Override Notion client version header if Notion updates their API
#                        Notion 客户端版本号，Notion 更新后可能需要同步修改
# NOTION_CLIENT_VERSION=23.13.20260228.0625

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL / 日志级别
LOG_LEVEL=INFO

# Timezone / 时区设置
TZ=Asia/Shanghai
